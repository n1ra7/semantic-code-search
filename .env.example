# Copy to .env and adjust as needed. All values have working defaults; nothing is secret.

# Self-hosted Qdrant (docker-compose starts one on :6333).
QDRANT_URL=http://localhost:6333
COLLECTION=code_chunks

# Local embedding model (downloaded once by FastEmbed, runs on CPU, no API key).
# Good options:
#   jinaai/jina-embeddings-v2-base-code   (768-dim, code-specialized — default)
#   BAAI/bge-small-en-v1.5                (384-dim, fastest/smallest)
#   nomic-ai/nomic-embed-text-v1.5        (768-dim, strong general)
EMBED_MODEL=jinaai/jina-embeddings-v2-base-code

# Incremental-index state (SQLite file).
STATE_DB=./index_state.sqlite

# Chunking / batching.
MAX_CHUNK_LINES=60
CHUNK_OVERLAP_LINES=10
BATCH_SIZE=64

# RAG chat via a local Ollama server (optional; `semantic-index chat`).
# Falls back to retrieval-only if unreachable. Pull the model once: `ollama pull qwen2.5-coder:7b`
OLLAMA_URL=http://localhost:11434
CHAT_MODEL=qwen2.5-coder:7b
